# Локальный override для конкретного сервера. НЕ коммитится в git.
#
# Docker Compose автоматически накладывает docker-compose.override.yml поверх
# базового docker-compose.yml, если оба лежат рядом. Сюда выносятся ТОЛЬКО
# настройки, специфичные для этой машины — базовый файл при обновлении из git
# их не затирает.
#
# Использование на сервере:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   # отредактировать под себя, затем:
#   docker compose up -d --build
#
# Большинство параметров (TEAMSTORM_API_URL, токен и т.п.) удобнее держать в .env —
# override нужен для того, что нельзя выразить переменной: другие порты, volume и пр.
# Раскомментируйте только нужные блоки.

services:
  teamstorm-mcp:
    # --- Пример: другие порты на хосте (если 3001/3002 заняты) ---
    # ports:
    #   - "3101:3001"   # MCP-эндпоинт
    #   - "3102:3002"   # health (внутри контейнера всегда PORT+1 = 3002)

    # --- Пример: дополнительные/переопределённые переменные окружения ---
    # environment:
    #   - TEAMSTORM_WORKSPACE=my-workspace
    #   - TRUST_PROXY=true          # только если перед сервером стоит доверенный reverse-proxy

    # --- Пример: примонтировать каталог логов с хоста ---
    # volumes:
    #   - /var/log/teamstorm-mcp:/app/logs
