# TeamStorm API Configuration
TEAMSTORM_API_URL=http://teamstorm.local/cwm/public/api/v1
# TEAMSTORM_API_TOKEN is optional in HTTP mode — each client passes its own token via Authorization header
# TEAMSTORM_API_TOKEN=your_private_token_here

# Server Configuration
PORT=3001
NODE_ENV=production

# Listen host. Default: 127.0.0.1 when TEAMSTORM_API_TOKEN is set (prevents anonymous remote sessions),
# 0.0.0.0 otherwise. Override explicitly for container/network deployments with a server token.
# LISTEN_HOST=0.0.0.0

# Optional: trust X-Forwarded-For header (enable only behind a reverse proxy)
# TRUST_PROXY=false